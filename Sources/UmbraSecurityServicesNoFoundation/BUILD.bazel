load("@build_bazel_rules_swift//swift:swift.bzl", "swift_library")
load("//:bazel/macros/swift.bzl", "umbra_swift_library")

# Foundation-free version of UmbraSecurityServices
# This module has NO dependencies on modules that import Foundation
umbra_swift_library(
    name = "UmbraSecurityServicesNoFoundation",
    srcs = glob(["**/*.swift"]),
    deps = [
        "//Sources/CoreTypes",
        "//Sources/ErrorHandling",
        "//Sources/SecurityInterfacesProtocols",
        "//Sources/SecurityInterfacesFoundationCore",
        "//Sources/SecurityInterfacesFoundationNoFoundation",
        "//Sources/FoundationBridgeTypes",
        "//Sources/UmbraSecurityNoFoundation",
    ],
)
